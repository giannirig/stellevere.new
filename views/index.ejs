<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StelleVere – Trova Artigiani Verificati</title>
  <meta name="description" content="Trova idraulici, elettricisti, imbianchini e altri artigiani verificati nella tua città. Recensioni vere, confermate via WhatsApp.">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#f5c842">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
  :root {
    --nero: #0a0a0a; --bg2: #111; --bg3: #1a1a1a;
    --bordo: #222; --testo: #e0e0e0; --muted: #666;
    --stella: #f5c842; --verde: #25d366;
  }
  html { scroll-behavior: smooth }
  body { background: var(--nero); font-family: 'Inter', sans-serif; color: var(--testo); min-height: 100vh }

  /* ── TOPBAR ── */
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 20px; height: 56px;
    border-bottom: 1px solid var(--bordo);
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,10,10,.96); backdrop-filter: blur(10px);
  }
  .logo { font-size: 20px; font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -.02em }
  .logo span { color: var(--stella) }
  .btn-artigiano {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--bg2); border: 1px solid var(--bordo);
    color: var(--testo); font-family: inherit; font-size: 13px; font-weight: 600;
    padding: 8px 14px; border-radius: 8px; text-decoration: none;
    transition: border-color .15s, background .15s;
    white-space: nowrap;
  }
  .btn-artigiano:hover { border-color: #444; background: var(--bg3) }

  /* ── HERO ── */
  .hero {
    padding: 52px 20px 40px;
    text-align: center;
    position: relative;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(245,200,66,.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-logo { font-size: 42px; margin-bottom: 10px }
  .hero-title { font-size: 32px; font-weight: 900; color: #fff; letter-spacing: -.03em; margin-bottom: 10px }
  .hero-title span { color: var(--stella) }
  .hero-sub { font-size: 15px; color: var(--muted); margin-bottom: 36px; line-height: 1.55; max-width: 380px; margin-left: auto; margin-right: auto }

  /* ── SEARCH ── */
  .search-wrap { width: 100%; max-width: 560px; margin: 0 auto; position: relative; z-index: 20 }
  .search-box {
    background: var(--bg2); border: 1.5px solid var(--bordo);
    border-radius: 16px; overflow: visible;
    box-shadow: 0 8px 40px rgba(0,0,0,.5);
    transition: border-color .2s;
  }
  .search-box:focus-within { border-color: #383838 }
  .s-row { display: flex; align-items: center; gap: 10px; padding: 12px 16px }
  .s-divider { height: 1px; background: var(--bordo) }
  .s-icon { font-size: 16px; opacity: .6; flex-shrink: 0 }
  .s-inp {
    flex: 1; background: none; border: none; outline: none;
    color: var(--testo); font-family: inherit; font-size: 15px; font-weight: 500; min-width: 0;
  }
  .s-inp::placeholder { color: #3a3a3a }
  .btn-cerca {
    display: block; width: calc(100% - 10px); margin: 5px;
    padding: 14px; background: var(--stella); color: #0a0a0a;
    border: none; border-radius: 11px;
    font-family: inherit; font-size: 15px; font-weight: 800;
    cursor: pointer; transition: opacity .15s, transform .1s;
  }
  .btn-cerca:hover { opacity: .9 }
  .btn-cerca:active { transform: scale(.98) }

  /* autocomplete */
  .ac-drop {
    position: absolute; top: calc(100% + 8px); left: 0; right: 0;
    background: #181818; border: 1px solid #2a2a2a; border-radius: 13px;
    overflow: hidden; z-index: 999; box-shadow: 0 12px 32px rgba(0,0,0,.6);
    display: none;
  }
  .ac-drop.open { display: block }
  .ac-item {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 16px; cursor: pointer; font-size: 14px;
    border-bottom: 1px solid #222; transition: background .1s;
  }
  .ac-item:last-child { border-bottom: none }
  .ac-item:hover, .ac-item.sel { background: rgba(245,200,66,.07) }
  .ac-em { font-size: 18px; width: 24px; text-align: center }
  .ac-nm { font-weight: 700; color: #fff }
  .ac-par { margin-left: auto; font-size: 12px; color: var(--muted) }

  /* ── CATEGORIE ── */
  .cats-section { padding: 40px 16px 16px; max-width: 620px; margin: 0 auto }
  .cats-title { font-size: 13px; font-weight: 700; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 14px; text-align: center }
  .cats-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
  }
  .cat-link {
    display: flex; flex-direction: column; align-items: center; gap: 7px;
    padding: 18px 10px;
    background: var(--bg2); border: 1px solid var(--bordo); border-radius: 13px;
    text-decoration: none; color: var(--testo);
    transition: border-color .18s, background .15s, transform .1s;
  }
  .cat-link:hover { border-color: var(--stella); background: var(--bg3) }
  .cat-link:active { transform: scale(.97) }
  .cat-em { font-size: 26px }
  .cat-nm { font-size: 13px; font-weight: 700; text-align: center; color: #ddd }

  /* ── COME FUNZIONA ── */
  .how { padding: 40px 20px 64px; max-width: 560px; margin: 0 auto }
  .how-title { font-size: 18px; font-weight: 800; color: #fff; text-align: center; margin-bottom: 24px }
  .step { display: flex; gap: 14px; align-items: flex-start; margin-bottom: 22px }
  .step-n {
    width: 30px; height: 30px; flex-shrink: 0;
    background: var(--stella); color: #0a0a0a; border-radius: 50%;
    font-weight: 900; font-size: 13px;
    display: flex; align-items: center; justify-content: center;
  }
  .step-t strong { display: block; font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 3px }
  .step-t p { font-size: 13px; color: var(--muted); line-height: 1.5 }

  @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-5px)} 75%{transform:translateX(5px)} }
  .shake { animation: shake .22s }
  .s-inp.err { color: #f87171 }

  @media(max-width:400px) {
    .cats-grid { grid-template-columns: repeat(2,1fr) }
    .hero-title { font-size: 26px }
    .btn-artigiano span { display: none }
  }
  </style>
</head>
<body>

<!-- TOPBAR -->
<nav class="topbar">
  <a class="logo" href="/">Stelle<span>Vere</span></a>
  <a class="btn-artigiano" href="/cerca_attivita">
    🔧 <span>Sei un artigiano?</span> Trova la tua scheda
  </a>
</nav>

<!-- HERO + SEARCH -->
<section class="hero">
  <div class="hero-logo">⭐</div>
  <h1 class="hero-title">Stelle<span>Vere</span></h1>
  <p class="hero-sub">Trova artigiani verificati vicino a te.<br>Stelle vere, non comprate.</p>

  <div class="search-wrap">
    <div class="search-box" id="searchBox">
      <div class="s-row">
        <span class="s-icon">🔍</span>
        <input id="inp-srv" class="s-inp" type="text"
               placeholder="Che lavoro ti serve? (es. idraulico…)"
               autocomplete="off" autocorrect="off" spellcheck="false">
      </div>
      <div class="s-divider"></div>
      <div class="s-row">
        <span class="s-icon">📍</span>
        <input id="inp-cit" class="s-inp" type="text"
               placeholder="Città (es. Milano, Roma…)"
               autocomplete="off">
      </div>
      <button class="btn-cerca" id="btnCerca">Cerca artigiani →</button>
    </div>
    <div class="ac-drop" id="acDrop"></div>
  </div>
  <p style="margin-top:14px;font-size:13px;color:#555">
    Cerchi un artigiano per nome?
    <a id="link-per-nome" href="/cerca_attivita" style="color:#888;text-decoration:underline;cursor:pointer">Sfoglia tutti gli artigiani →</a>
  </p>
</section>

<!-- CATEGORIE -->
<div class="cats-section">
  <p class="cats-title">Sfoglia per categoria</p>
  <div class="cats-grid">
    <% const EM = {'drop':'💧','zap':'⚡','paint':'🎨','wall':'🧱','wood':'🪵','tool':'🔧'}; %>
    <% for (const [slug, cat] of Object.entries(categorie)) { %>
    <a class="cat-link" href="/<%= slug %>">
      <span class="cat-em"><%= (EM[cat.icona] || '🔧') %></span>
      <span class="cat-nm"><%= cat.nome %></span>
    </a>
    <% } %>
  </div>
</div>

<!-- COME FUNZIONA -->
<div class="how">
  <h2 class="how-title">Come funziona</h2>
  <div class="step">
    <div class="step-n">1</div>
    <div class="step-t">
      <strong>Cerca il professionista</strong>
      <p>Digita il tipo di lavoro e la tua città. Mostriamo solo artigiani con lavori documentati.</p>
    </div>
  </div>
  <div class="step">
    <div class="step-n">2</div>
    <div class="step-t">
      <strong>Leggi le recensioni verificate</strong>
      <p>Ogni stella è confermata via WhatsApp direttamente dal cliente che ha fatto il lavoro.</p>
    </div>
  </div>
  <div class="step">
    <div class="step-n">3</div>
    <div class="step-t">
      <strong>Contatta e prenota</strong>
      <p>Un click su WhatsApp e sei in contatto con l'artigiano. Nessun intermediario.</p>
    </div>
  </div>
</div>

<script>
const CAT_DATA    = <%- JSON.stringify(categorie) %>;
const SUBCAT_DATA = <%- JSON.stringify(sottocategorie) %>;
const EMOJI = { drop:'💧', zap:'⚡', paint:'🎨', wall:'🧱', wood:'🪵', tool:'🔧' };

const CAT_ALIAS = {
  idraulica:    ['idraulico','idraulici','perdita','perdita acqua','tubo','tubatura',
                 'termosifone','riscaldamento','boiler','scaldabagno','rubinetto','scarico',
                 'bagno','wc','doccia','vasca','caldaia','impianto idrico'],
  elettricista: ['elettricista','elettricisti','elettrico','impianto elettrico','corrente',
                 'luce','luci','quadro','presa','interruttore','guasto elettrico',
                 'fotovoltaico','pannelli solari','domotica','climatizzatore'],
  imbianchino:  ['imbianchino','pittore','pittura','tinteggiatura','vernice','verniciatura',
                 'intonaco','parete','pareti','stucco','carta da parati','tintegg'],
  muratore:     ['muratore','ristrutturazione','piastrella','piastrelle','pavimento','pavimenti',
                 'demolizione','muro','muratura','solaio','impermeabilizzazione'],
  falegname:    ['falegname','legno','porta','porte','armadio','cucina','finestra','finestre',
                 'infisso','parquet','mobile','mobili','restauro','serranda'],
  altro:        ['giardiniere','giardinaggio','condizionatore','trasloco','montaggio mobili',
                 'fabbro','serratura','pulizie','potatura'],
};

// Indice ricerca
const indice = [];
for (const [cs, cat] of Object.entries(CAT_DATA)) {
  const em = EMOJI[cat.icona] || '🔧';
  indice.push({
    tipo:'cat', catSlug:cs, subSlug:null,
    label:cat.nome, emoji:em, parentLabel:null,
    kw:[cat.nome.toLowerCase(), cs, ...(CAT_ALIAS[cs]||[])]
  });
  for (const [ss, sub] of Object.entries(SUBCAT_DATA[cs]||{})) {
    const base = sub.nome.toLowerCase();
    indice.push({
      tipo:'sub', catSlug:cs, subSlug:ss,
      label:sub.nome, emoji:em, parentLabel:cat.nome,
      kw:[base, ss.replace(/-/g,' '),
          base.replace(/[ie]$/,''), base.replace(/[ie]$/,'a'),
          cat.nome.toLowerCase(), cs]
    });
  }
}

function slugify(t) {
  return (t||'').toLowerCase()
    .replace(/[àáâã]/g,'a').replace(/[èéêë]/g,'e')
    .replace(/[ìíîï]/g,'i').replace(/[òóôõ]/g,'o')
    .replace(/[ùúûü]/g,'u').replace(/ç/g,'c').replace(/ñ/g,'n')
    .replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');
}

function cercaVoce(q) {
  q = q.toLowerCase().trim();
  if (!q) return null;
  for (const v of indice) if (v.kw.some(k => k === q)) return v;
  if (q.length >= 3) for (const v of indice) if (v.kw.some(k => k.startsWith(q))) return v;
  for (const v of indice) if (v.kw.some(k => k.includes(q))) return v;
  for (const v of indice) if (v.kw.some(k => k.length >= 4 && q.includes(k))) return v;
  return null;
}

function buildUrl(voce, citta) {
  const c = slugify(citta);
  if (!voce) return null;
  if (voce.tipo === 'sub')
    return c ? `/${voce.catSlug}/${voce.subSlug}/${c}` : `/${voce.catSlug}/${voce.subSlug}`;
  return c ? `/${voce.catSlug}/${c}` : `/${voce.catSlug}`;
}

function shake() {
  const box = document.getElementById('searchBox');
  box.classList.add('shake');
  setTimeout(() => box.classList.remove('shake'), 300);
}

function eseguiRicerca() {
  const srv = document.getElementById('inp-srv').value.trim();
  const cit = document.getElementById('inp-cit').value.trim();
  if (!srv) { document.getElementById('inp-srv').focus(); shake(); return; }
  const voce = cercaVoce(srv);
  const params = new URLSearchParams();
  params.set('q', srv);
  if (cit) params.set('dove', cit);
  if (voce && voce.catSlug) params.set('cat', voce.catSlug);
  if (voce && voce.subSlug) params.set('subcat', voce.subSlug);
  window.location.href = '/mappa-lavori?' + params.toString();
}

document.getElementById('btnCerca').addEventListener('click', eseguiRicerca);
document.getElementById('inp-cit').addEventListener('keydown', e => { if(e.key==='Enter') eseguiRicerca(); });

// Aggiorna link "sfoglia per nome" con il termine digitato
document.getElementById('inp-srv').addEventListener('input', function() {
  const v = this.value.trim();
  const lnk = document.getElementById('link-per-nome');
  if (v) {
    lnk.href = '/cerca_attivita?q=' + encodeURIComponent(v);
    lnk.textContent = 'Cerca "' + v + '" tra gli artigiani →';
  } else {
    lnk.href = '/cerca_attivita';
    lnk.textContent = 'Sfoglia tutti gli artigiani →';
  }
});

// Autocomplete
const acDrop = document.getElementById('acDrop');
let acItems = [], acSel = -1;

function renderAc(q) {
  q = q.toLowerCase().trim();
  acDrop.innerHTML = ''; acSel = -1;
  if (!q || q.length < 2) { acDrop.classList.remove('open'); return; }
  acItems = indice.filter(v => v.kw.some(k => k.includes(q)||q.includes(k))).slice(0, 7);
  if (!acItems.length) { acDrop.classList.remove('open'); return; }
  acItems.forEach((v, i) => {
    const el = document.createElement('div');
    el.className = 'ac-item';
    el.innerHTML = `<span class="ac-em">${v.emoji}</span><span class="ac-nm">${v.label}</span>${v.parentLabel?`<span class="ac-par">${v.parentLabel}</span>`:''}`;
    el.addEventListener('mousedown', e => {
      e.preventDefault();
      document.getElementById('inp-srv').value = v.label;
      acDrop.classList.remove('open');
      document.getElementById('inp-cit').focus();
    });
    acDrop.appendChild(el);
  });
  acDrop.classList.add('open');
}

const inpSrv = document.getElementById('inp-srv');
inpSrv.addEventListener('input', e => renderAc(e.target.value));
inpSrv.addEventListener('focus', e => { if(e.target.value.length>=2) renderAc(e.target.value); });
inpSrv.addEventListener('blur', () => setTimeout(() => acDrop.classList.remove('open'), 160));
inpSrv.addEventListener('keydown', e => {
  const rows = acDrop.querySelectorAll('.ac-item');
  if (e.key==='ArrowDown') { acSel=Math.min(acSel+1,rows.length-1); rows.forEach((r,i)=>r.classList.toggle('sel',i===acSel)); e.preventDefault(); }
  else if (e.key==='ArrowUp') { acSel=Math.max(acSel-1,0); rows.forEach((r,i)=>r.classList.toggle('sel',i===acSel)); e.preventDefault(); }
  else if (e.key==='Enter') {
    if (acSel>=0 && acItems[acSel]) {
      inpSrv.value = acItems[acSel].label;
      acDrop.classList.remove('open');
      document.getElementById('inp-cit').focus();
    } else { eseguiRicerca(); }
  }
});
</script>
</body>
</html>
