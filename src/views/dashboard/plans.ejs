<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Piani lavori</title>
    <style>
      body { margin: 0; font-family: Georgia, serif; background: #f6f1e8; color: #241d18; }
      main { max-width: 980px; margin: 0 auto; padding: 20px 14px 60px; display: grid; gap: 16px; }
      .panel { background: #fffaf5; border: 1px solid #e7d8c8; border-radius: 24px; padding: 20px; }
      .plans { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
      .plan { background: #fff; border: 1px solid #ead8c3; border-radius: 18px; padding: 16px; }
      .active { box-shadow: 0 0 0 2px rgba(186, 94, 13, 0.18); }
      .muted { color: #6e6258; }
      .cta { display: inline-block; background: #bc5d08; color: #fff; text-decoration: none; border-radius: 999px; padding: 12px 16px; }
      a { color: #bc5d08; text-decoration: none; }
    </style>
  </head>
  <body>
    <main>
      <a href="/dashboard/<%= artigiano.slug %>">← Torna alla dashboard</a>
      <section class="panel">
        <h1>Piani disponibili</h1>
        <p class="muted">Scegli il piano che ti permette di pubblicare più lavori.</p>
        <div class="plans">
          <% plans.forEach(function(plan) { %>
            <article class="plan <%= plan.slug === activePlan.slug ? 'active' : '' %>">
              <strong><%= plan.nome %></strong>
              <p class="muted">€ <%= plan.prezzo %><%= plan.slug === 'free' ? '' : '/mese' %></p>
              <p><%= plan.maxLavori === null ? 'Lavori illimitati' : 'Fino a ' + plan.maxLavori + ' lavori' %></p>
              <% if (plan.slug === activePlan.slug) { %>
                <p><strong>Piano attuale</strong></p>
              <% } else { %>
                <a class="cta" href="/dashboard/<%= artigiano.slug %>">Scegli questo piano</a>
              <% } %>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
  </body>
</html>
