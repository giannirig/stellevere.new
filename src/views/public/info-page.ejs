<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | StelleVere</title>
    <style>
      :root {
        --bg: #111317;
        --surface: rgba(26, 30, 36, 0.95);
        --ink: #f2ece5;
        --muted: #b1a79a;
        --line: #343b45;
        --accent: #d48a53;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Georgia, serif;
        color: var(--ink);
        background: linear-gradient(180deg, #111317 0%, #171b21 100%);
      }
      main {
        max-width: 920px;
        margin: 0 auto;
        padding: 18px 14px 48px;
        display: grid;
        gap: 16px;
      }
      .panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
      }
      .eyebrow {
        font-size: 12px;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }
      h1, h2, p { margin: 0; }
      h1 { font-size: clamp(32px, 8vw, 54px); line-height: 1; }
      h2 { font-size: 24px; line-height: 1.1; margin-bottom: 8px; }
      p { color: var(--muted); line-height: 1.55; }
      .stack { display: grid; gap: 12px; }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
      }
      @media (min-width: 760px) {
        main { padding: 28px 18px 60px; }
        .panel { padding: 24px; }
      }
    </style>
  </head>
  <body>
    <main>
      <a class="back-link" href="/">← Torna alla home</a>

      <section class="panel stack">
        <div class="eyebrow"><%= eyebrow %></div>
        <h1><%= title %></h1>
        <p><%= intro %></p>
      </section>

      <% sections.forEach(function(section) { %>
        <section class="panel stack">
          <h2><%= section.title %></h2>
          <p><%= section.body %></p>
        </section>
      <% }) %>
    </main>
  </body>
</html>
