<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href="<%= canonicalUrl %>" />
    <title><%= lavoro.titolo %> | StelleVere</title>
    <script type="application/ld+json">
      <%- JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'CreativeWork',
        name: lavoro.titolo,
        description: lavoro.descrizione || 'Lavoro pubblicato su StelleVere.',
        image: Array.isArray(lavoro.immagini) && lavoro.immagini.length
          ? lavoro.immagini.map(function (immagine) {
              return immagine.src && immagine.src.startsWith('data:') ? undefined : `${baseUrl}/uploads/${immagine.src}`;
            }).filter(Boolean)
          : (lavoro.cover_path && !lavoro.cover_path.startsWith('data:') ? [`${baseUrl}/uploads/${lavoro.cover_path}`] : undefined),
        author: {
          '@type': 'LocalBusiness',
          name: lavoro.artigiano_nome,
          url: `${baseUrl}/artigiano/${lavoro.artigiano_slug}`
        },
        url: canonicalUrl
      }).replace(/</g, '\\u003c') %>
    </script>
    <style>
      body { margin: 0; font-family: Georgia, serif; background: #f6f1e8; color: #241d18; }
      main { max-width: 980px; margin: 0 auto; padding: 28px 16px 52px; display: grid; gap: 18px; }
      .panel { background: #fffaf5; border: 1px solid #e7d8c8; border-radius: 24px; padding: 22px; }
      .gallery-grid { display: grid; gap: 12px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .gallery-item { aspect-ratio: 4 / 3; border-radius: 18px; overflow: hidden; background: #f0e3d2; display: grid; place-items: center; color: #8a6b4f; }
      .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .muted { color: #6e6258; }
      .row { display: flex; gap: 8px; flex-wrap: wrap; }
      .badge { border: 1px solid #e7d8c8; border-radius: 999px; padding: 7px 11px; background: #fff; }
      .cta { display: inline-block; padding: 12px 16px; border-radius: 999px; background: #bc5d08; color: #fff; text-decoration: none; }
      .cta.secondary { background: #efe2d5; color: #6d5744; }
      .review-list { display: grid; gap: 12px; }
      .review-card { border: 1px solid #e7d8c8; border-radius: 18px; padding: 16px; background: #fff; }
      @media (min-width: 760px) {
        .gallery-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="panel">
        <div class="gallery-grid">
          <% if (Array.isArray(lavoro.immagini) && lavoro.immagini.length) { %>
            <% lavoro.immagini.forEach(function(immagine, index) { %>
              <div class="gallery-item">
                <img src="<%= immagine.src && immagine.src.startsWith('data:') ? immagine.src : '/uploads/' + immagine.src %>" alt="<%= immagine.alt || (lavoro.titolo + ' ' + (index + 1)) %>" />
              </div>
            <% }) %>
          <% } else if (lavoro.cover_path) { %>
            <div class="gallery-item">
              <img src="<%= lavoro.cover_path.startsWith('data:') ? lavoro.cover_path : '/uploads/' + lavoro.cover_path %>" alt="<%= lavoro.cover_alt || lavoro.titolo %>" />
            </div>
          <% } else { %>
            <div class="gallery-item">
              <span>Immagini del lavoro</span>
            </div>
          <% } %>
        </div>
      </section>

      <section class="panel">
        <h1><%= lavoro.titolo %></h1>
        <div class="row">
          <span class="badge"><%= lavoro.categoria_nome %></span>
          <% if (lavoro.citta) { %><span class="badge"><%= lavoro.citta %></span><% } %>
          <% if (lavoro.quartiere) { %><span class="badge"><%= lavoro.quartiere %></span><% } %>
        </div>
        <p><%= lavoro.descrizione || 'Lavoro pubblicato su StelleVere.' %></p>

        <% if (Array.isArray(recensioni) && recensioni.length) { %>
          <div style="margin-top: 20px;">
            <h2>Recensione su questo lavoro</h2>
            <div class="review-list" style="margin-top: 14px;">
              <% recensioni.forEach(function(recensione) { %>
                <article class="review-card">
                  <p style="margin-top: 0;"><%= recensione.testo %></p>
                  <div class="row" style="margin-top: 8px;">
                    <span class="badge"><%= recensione.cliente_nome %></span>
                    <span class="badge"><%= Number(recensione.voto || 0).toFixed(0) %>/5</span>
                    <% if (recensione.data_recensione) { %><span class="badge"><%= new Date(recensione.data_recensione).toLocaleDateString('it-IT') %></span><% } %>
                  </div>
                </article>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="row" style="margin-top: 10px;">
          <a class="cta" href="/artigiano/<%= lavoro.artigiano_slug %>">Vedi scheda artigiano</a>
          <a class="cta secondary" href="/<%= lavoro.categoria_slug %>/<%= lavoro.seo_intervento_slug || lavoro.tipo_slug %>/<%= lavoro.seo_citta_slug || lavoro.citta %>/<%= lavoro.seo_quartiere_slug || lavoro.quartiere %>">Altri lavori simili nella tua zona</a>
        </div>
      </section>
    </main>
  </body>
</html>
