<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <style>
      body { margin: 0; font-family: Georgia, serif; background: #f6f1e8; color: #241d18; display: grid; place-items: center; min-height: 100vh; }
      main { max-width: 640px; padding: 32px; background: #fffaf5; border: 1px solid #e7d8c8; border-radius: 24px; text-align: center; }
      a { color: #bc5d08; text-decoration: none; }
    </style>
  </head>
  <body>
    <main>
      <h1><%= title %></h1>
      <p><%= message %></p>
      <p><a href="/">Torna alla home V2</a></p>
    </main>
  </body>
</html>
